@model IEnumerable<Product>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Product Management";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container-fluid py-4 px-4">

    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="fw-bold text-dark mb-1">Product Management</h2>
            <p class="text-muted small mb-0">Manage your catalog, pricing, and stock levels.</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a asp-action="Archived" class="btn btn-outline-secondary border-0 fw-semibold me-2">
                <i class="fas fa-archive me-2"></i>View Archives
            </a>
            <a asp-action="Create" class="btn btn-primary px-4 shadow-sm fw-bold">
                <i class="fas fa-plus me-2"></i>Add New Product
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 border-0 text-muted small text-uppercase fw-bold py-3">Product Name</th>
                            <th class="border-0 text-muted small text-uppercase fw-bold py-3">Category</th>
                            <th class="border-0 text-muted small text-uppercase fw-bold py-3">Price</th>
                            <th class="border-0 text-muted small text-uppercase fw-bold py-3">Stock</th>
                            <th class="border-0 text-muted small text-uppercase fw-bold py-3">Status</th> @* Added header *@
                            <th class="border-0 text-muted small text-uppercase fw-bold py-3 text-center" width="200">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.Status == "Inactive" ? "bg-light opacity-75" : "")">
                                @* Subtly dim inactive rows *@
                                <td class="ps-4 py-3 fw-bold text-dark">@item.ProductName</td>
                                <td><span class="badge bg-light text-secondary border fw-medium px-3 py-2">@item.Category</span></td>
                                <td>₱ @item.Price.ToString("N2")</td>
                                <td>
                                    @if (item.StockQuantity <= item.ReorderLevel)
                                    {
                                        <span class="text-danger fw-bold" title="Low Stock Alert!">
                                            <i class="fas fa-exclamation-triangle me-1"></i> @item.StockQuantity
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-dark">@item.StockQuantity</span>
                                    }
                                </td>

                                <td>
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3">
                                            <i class="fas fa-check-circle me-1 small"></i> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary px-3">
                                            <i class="fas fa-eye-slash me-1 small"></i> Inactive
                                        </span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="btn-group shadow-sm rounded">
                                        <button type="button" class="btn btn-white btn-sm border-end px-3"
                                                data-bs-toggle="modal" data-bs-target="#stockModal-@item.Id" title="Add Stock">
                                            <i class="fas fa-plus text-success"></i>
                                        </button>

                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-white btn-sm border-end px-3" title="Edit">
                                            <i class="fas fa-pen text-warning"></i>
                                        </a>
                                        <a asp-action="Archive" asp-route-id="@item.Id" class="btn btn-white btn-sm px-3" title="Archive">
                                            <i class="fas fa-box-archive text-danger"></i>
                                        </a>
                                    </div>
                                    <div class="modal fade" id="stockModal-@item.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-sm modal-dialog-centered">
                                            <div class="modal-content border-0 shadow-lg">
                                                <form asp-action="UpdateStock" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <div class="modal-header border-0 bg-light">
                                                        <h6 class="modal-title fw-bold">Stock Entry</h6>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body text-start">
                                                        <label class="small text-muted mb-2">Adding stock for <strong>@item.ProductName</strong></label>
                                                        <input type="number" name="amount" class="form-control" placeholder="Quantity to add" required min="1" />
                                                    </div>
                                                    <div class="modal-footer border-0">
                                                        <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-success btn-sm">Update Stock</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white border-0 py-3 text-center">
            <small class="text-muted">Showing <strong>@Model.Count()</strong> active products in your catalog</small>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }

    .table thead th {
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }

    .btn-white {
        background: #fff;
        border: 1px solid #dee2e6;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }

    .bg-success-subtle {
        background-color: #e1f7ec !important;
    }

    .text-success {
        color: #0f5132 !important;
    }
</style>