@model IEnumerable<Expense>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Expense Management";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Expense Management</h3>
        <a asp-action="CreateExpense" class="btn btn-primary rounded-3 shadow-sm">
            + Add Expense
        </a>
        <a asp-action="ArchivedExpenses" class="btn btn-secondary rounded-3 shadow-sm me-2">
            Archived Expenses
        </a>
    </div>

    <div class="card shadow rounded-4 border-0">
        <div class="card-body">

            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Description</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">
                                No expenses recorded.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var expense in Model)
                        {
                            <tr>
                                <td>@expense.Description</td>
                                <td>₱ @expense.Amount.ToString("N2")</td>
                                <td>@expense.ExpenseDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-center">

                                    <a asp-action="EditExpense"
                                       asp-route-id="@expense.Id"
                                       class="btn btn-sm btn-warning me-1">
                                        Edit
                                    </a>

                                    <a asp-action="Archive"
                                       asp-route-id="@expense.Id"
                                       class="btn btn-sm btn-secondary me-1"
                                       onclick="return confirm('Are you sure you want to archive this expense?');">
                                        Archive
                                    </a>

                                    <a asp-action="DeletePermanent"
                                       asp-route-id="@expense.Id"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Permanently delete this expense? This cannot be undone!');">
                                        Delete
                                    </a>

                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>