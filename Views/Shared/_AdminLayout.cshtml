@using Microsoft.AspNetCore.Identity
@using Executive_Fuentes.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ELF</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --sidebar-bg: #0f172a;
            --accent-blue: #38bdf8;
            --text-muted: #94a3b8;
            --body-bg: #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--body-bg);
            margin: 0;
            overflow-x: hidden;
        }

        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            width: 260px;
            min-width: 260px;
            background-color: var(--sidebar-bg);
            color: var(--text-muted);
            display: flex;
            flex-direction: column;
            position: sticky;
            top: 0;
            height: 100vh;
            z-index: 1000;
        }

        .sidebar-brand {
            padding: 2rem 1.5rem;
            color: white;
            font-weight: 700;
            font-size: 1.25rem;
            text-decoration: none;
            display: flex;
            align-items: center;
        }

        .section-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1px;
            padding: 1.5rem 1.5rem 0.5rem;
            color: #475569;
        }

        .nav-link {
            color: var(--text-muted);
            padding: 0.8rem 1.5rem;
            display: flex;
            align-items: center;
            text-decoration: none !important;
            transition: 0.2s;
            font-weight: 500;
        }

            .nav-link i {
                margin-right: 12px;
                font-size: 1.1rem;
            }

            .nav-link:hover:not(.active) {
                background-color: #1e293b;
                color: white;
            }

            .nav-link.active {
                background-color: var(--accent-blue);
                color: #0f172a !important;
                font-weight: 600;
            }

        /* --- MAIN CONTENT --- */
        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            min-width: 0; /* Prevents flexbox overflow */
        }

        .top-navbar {
            background: white;
            padding: 1rem 2rem;
            border-bottom: 1px solid #e2e880;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .content-padding {
            padding: 2rem;
            flex-grow: 1;
        }

        /* Custom Scrollbar for Sidebar */
        .sidebar::-webkit-scrollbar {
            width: 5px;
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: #334155;
        }
    </style>
</head>
<body>

    <div class="admin-wrapper">
        <nav class="sidebar">
            <a class="sidebar-brand" href="/">
                <i class="bi bi-shield-lock-fill text-info me-2"></i> ELF Executive Trade & Services
            </a>

            <div class="section-label">Core</div>
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "AdminDashboard" ? "active" : "")"
               asp-controller="Dashboard" asp-action="AdminDashboard">
                <i class="bi bi-speedometer2"></i> KPI Monitoring
            </a>

            <div class="section-label">Management</div>
            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Executive"))
            {
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Finance" asp-action="Index">
                        <i class="bi bi-box"></i> Financials
                    </a>
                </li>
            }
            <!-- SALES SECTION -->
            @if (User.IsInRole("AuthorizedUser"))
            {
                <!-- AuthorizedUser ONLY sees Sales & Marketing (no dropdown) -->
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "SalesMarketing" ? "active" : "")"
                   asp-controller="SalesMarketing" asp-action="Index">
                    <i class="bi bi-bar-chart-line"></i> Sales & Marketing
                </a>
            }
            else
            {
                <!-- Other roles see the dropdown -->
                <a class="nav-link d-flex justify-content-between align-items-center"
                   data-bs-toggle="collapse"
                   href="#salesMenu"
                   role="button"
                   aria-expanded="false"
                   aria-controls="salesMenu">
                    <span><i class="bi bi-graph-up-arrow"></i> Sales</span>
                    <i class="bi bi-chevron-down small"></i>
                </a>

                <div class="collapse @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Sales"
                                                || ViewContext.RouteData.Values["Controller"]?.ToString() == "SalesMarketing"
                                                ? "show" : "")"
                 id="salesMenu">

                    <a class="nav-link ms-4 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Sales" ? "active" : "")"
                       asp-controller="Sales" asp-action="Index">
                        <i class="bi bi-list-ul"></i> Sales List
                    </a>

                    <a class="nav-link ms-4 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "SalesMarketing" ? "active" : "")"
                       asp-controller="SalesMarketing" asp-action="Index">
                        <i class="bi bi-bar-chart-line"></i> Sales & Marketing
                    </a>

                </div>
                        }
            @if (User.IsInRole("SuperAdmin") || User.IsInRole("HeadManager") || User.IsInRole("Executive"))
            {
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box"></i> Products
                    </a>
                </li>
            }
            <a class="nav-link" asp-controller="StrategicReport" asp-action="Index">
                <i class="bi bi-file-earmark-bar-graph"></i> Analytics
            </a>
            
            @if (User.IsInRole("SuperAdmin"))
            {
                <div class="section-label">Advanced</div>
            }
            
            
            @if (User.IsInRole("SuperAdmin"))
            {
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Audit" asp-action="Index">
                        <i class="bi bi-box"></i> Audit Logs
                    </a>
                </li>
            }
            @if (User.IsInRole("SuperAdmin"))
            {
                <li class="nav-item">
                    <a class="nav-link" asp-controller="User" asp-action="Index">Manage Users</a>
                </li>
            }

            <div class="mt-auto mb-4">
                <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                    <button type="submit" class="nav-link text-danger border-0 bg-transparent w-100 text-start">
                        <i class="bi bi-box-arrow-left"></i> Logout
                    </button>
                </form>
            </div>
        </nav>

        <main class="main-content">
            <header class="top-navbar">
                <h5 class="m-0 fw-bold text-dark">@ViewData["Title"]</h5>
                <div class="user-info small text-muted">
                    Logged in as: <span class="fw-bold text-dark">@UserManager.GetUserName(User)</span>
                </div>
            </header>

            <div class="content-padding">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>