@model Product
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Confirm Permanent Delete";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="text-center mb-4">
                <div class="display-4 text-danger mb-2">
                    <i class="fas fa-triangle-exclamation animate-bounce"></i>
                </div>
                <h2 class="fw-bold text-dark">Permanent Delete?</h2>
                <p class="text-muted small">
                    This action <span class="text-danger fw-bold">cannot be undone</span>.
                    All data associated with this product will be scrubbed from the system.
                </p>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-danger" style="height: 6px;"></div>

                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="p-3 bg-danger-subtle rounded-3 me-3 text-danger">
                            <i class="fas fa-trash-can fa-xl"></i>
                        </div>
                        <div>
                            <h6 class="text-uppercase text-muted small fw-bold mb-0">Product to be removed</h6>
                            <h5 class="fw-bold mb-0">@Model.ProductName</h5>
                        </div>
                    </div>

                    <div class="border rounded-3 p-3 mb-4 bg-light bg-opacity-50">
                        <div class="row mb-2">
                            <div class="col-4 text-muted small">Category</div>
                            <div class="col-8 fw-semibold text-end">@Model.Category</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-4 text-muted small">Final Price</div>
                            <div class="col-8 fw-semibold text-end">₱ @Model.Price.ToString("N2")</div>
                        </div>
                        <div class="row">
                            <div class="col-4 text-muted small">Current Status</div>
                            <div class="col-8 text-end">
                                <span class="badge bg-secondary-subtle text-secondary border">@Model.Status</span>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger py-3 fw-bold shadow-sm">
                                <i class="fas fa-trash-can me-2"></i>Delete Permanently
                            </button>
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted py-2">
                                No, I changed my mind
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <div class="p-3 bg-white border rounded-3 small text-muted shadow-sm">
                    <i class="fas fa-shield-halved text-primary me-2"></i>
                    For security, this deletion will be logged in the system audit trail.
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #fdf2f2;
    }
    /* Very soft red tint background */
    .card {
        border-radius: 1.25rem;
    }

    .bg-danger-subtle {
        background-color: #fee2e2 !important;
    }

    .btn-danger {
        background-color: #dc3545;
        border: none;
        transition: all 0.2s;
    }

        .btn-danger:hover {
            background-color: #bb2d3b;
            transform: scale(1.02);
        }

    /* Subtle bounce for the alert icon */
    @@keyframes bounce {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    .animate-bounce {
        animation: bounce 2s infinite;
    }
</style>