@model Product
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Create Product";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary py-3">
                    <h5 class="card-title mb-0 text-white fw-bold">
                        <i class="fas fa-plus-circle me-2"></i>New Product Specification
                    </h5>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="StockQuantity" class="form-label fw-semibold text-dark">Initial Stock</label>
                                <div class="input-group border rounded-3 overflow-hidden shadow-sm">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-boxes-stacked text-muted"></i></span>
                                    <input asp-for="StockQuantity" type="number" class="form-control border-0 py-2" placeholder="0" />
                                </div>
                                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ReorderLevel" class="form-label fw-semibold text-dark">Reorder Level (Alert)</label>
                                <div class="input-group border rounded-3 overflow-hidden shadow-sm">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-bell text-muted"></i></span>
                                    <input asp-for="ReorderLevel" type="number" class="form-control border-0 py-2" />
                                </div>
                                <span asp-validation-for="ReorderLevel" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="ProductName" class="form-label fw-semibold text-dark">Product Identification</label>
                                <div class="input-group border rounded-3 overflow-hidden shadow-sm">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-tag text-muted"></i></span>
                                    <input asp-for="ProductName" class="form-control border-0 py-2" placeholder="e.g. Premium Wireless Headphones" />
                                </div>
                                <span asp-validation-for="ProductName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Category" class="form-label fw-semibold text-dark">Inventory Category</label>
                                <div class="input-group border rounded-3 overflow-hidden shadow-sm">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-layer-group text-muted"></i></span>
                                    <input asp-for="Category" class="form-control border-0 py-2" placeholder="e.g. Beverage" />
                                </div>
                                <span asp-validation-for="Category" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Price" class="form-label fw-semibold text-dark">Unit Price</label>
                                <div class="input-group border rounded-3 overflow-hidden shadow-sm">
                                    <span class="input-group-text bg-light border-0 text-muted fw-bold">₱</span>
                                    <input asp-for="Price" class="form-control border-0 py-2" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Status" class="form-label fw-semibold text-dark">Catalog Status</label>
                                <div class="input-group border rounded-3 overflow-hidden shadow-sm">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-toggle-on text-muted"></i></span>
                                    <select asp-for="Status" class="form-select border-0 py-2">
                                        <option value="" disabled selected>Select visibility status...</option>
                                        <option value="Active">Active </option>
                                        <option value="Inactive">Inactive </option>
                                    </select>
                                </div>
                                <span asp-validation-for="Status" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-5 d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 py-2 fw-bold shadow-sm">
                                <i class="fas fa-check-circle me-2"></i>Register Product
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-semibold border-0">
                                Discard Changes
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted small">
                    <i class="fas fa-info-circle me-1"></i>
                    Double-check price entries to ensure correct tax calculations on checkout.
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f3f6f9;
    }

    .form-control:focus, .form-select:focus {
        box-shadow: none;
        background-color: #fff;
    }

    .input-group:focus-within {
        border-color: #0d6efd !important;
        ring: 2px rgba(13, 110, 253, 0.25);
    }

    .card {
        border-radius: 1rem;
    }

    .btn-primary {
        border-radius: 8px;
        transition: all 0.2s;
    }

        .btn-primary:hover {
            transform: translateY(-1px);
        }
</style>