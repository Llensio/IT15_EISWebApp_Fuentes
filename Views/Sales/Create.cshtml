@model Sale
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var isEdit = ViewData["Title"]?.ToString().Contains("Edit") ?? false;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg">
                <div class="card-header @(isEdit ? "bg-warning" : "bg-primary") py-3">
                    <h5 class="card-title mb-0 text-white fw-bold">
                        <i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") me-2"></i>
                        @(isEdit ? "Update Sale Record" : "Add New Sale")
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                        @Html.AntiForgeryToken()
                        @if (isEdit)
                        {
                            <input type="hidden" asp-for="Id" />
                        }

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Select Product</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-box"></i></span>
                                <select asp-for="ProductId" class="form-select shadow-sm" asp-items="@(new SelectList(ViewBag.Products, "Id", "ProductName"))">
                                    <option value="">-- Choose Product --</option>
                                </select>
                            </div>
                            <span asp-validation-for="ProductId" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-semibold">Quantity</label>
                                <input asp-for="QuantitySold" class="form-control shadow-sm" placeholder="0" />
                                <span asp-validation-for="QuantitySold" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-semibold">Sale Date</label>
                                <input asp-for="SaleDate" type="date" class="form-control shadow-sm" />
                                <span asp-validation-for="SaleDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 text-muted">

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn @(isEdit ? "btn-warning" : "btn-primary") px-5 shadow-sm">
                                @(isEdit ? "Save Changes" : "Confirm Sale")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>