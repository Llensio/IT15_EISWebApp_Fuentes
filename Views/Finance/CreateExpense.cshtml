@model Expense
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add Expense";
}

<div class="container py-4">

    <div class="card shadow rounded-4 border-0">
        <div class="card-body p-4">

            <h4 class="mb-4">Add New Expense</h4>

            <form asp-action="CreateExpense" method="post">

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <input asp-for="Description" class="form-control rounded-3" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Amount</label>
                    <input asp-for="Amount" class="form-control rounded-3" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Expense Date</label>
                    <input asp-for="ExpenseDate" type="date" class="form-control rounded-3" />
                </div>

                <button type="submit" class="btn btn-primary rounded-3">
                    Save Expense
                </button>

                <a asp-action="Expenses" class="btn btn-secondary rounded-3 ms-2">
                    Cancel
                </a>

            </form>

        </div>
    </div>

</div>