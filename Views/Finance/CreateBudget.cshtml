@model Budget
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Create Budget";
}

<div class="container py-4">

    <div class="card shadow rounded-4 border-0">
        <div class="card-body p-4">

            <h4 class="mb-4">Create New Budget</h4>

            <form asp-action="CreateBudget" method="post">

                <div class="mb-3">
                    <label class="form-label">Budget Amount</label>
                    <input asp-for="Amount" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label class="form-label">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control rounded-3" />
                </div>

                <button type="submit" class="btn btn-success rounded-3">
                    Save Budget
                </button>

                <a asp-action="Budgets" class="btn btn-secondary rounded-3 ms-2">
                    Cancel
                </a>

            </form>

        </div>
    </div>

</div>