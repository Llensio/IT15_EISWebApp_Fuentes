@model Budget
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Budget";
}

<div class="container py-4">

    <div class="card shadow rounded-4 border-0">
        <div class="card-body p-4">

            <h4 class="mb-4">Edit Budget</h4>

            <form asp-action="EditBudget" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Budget Amount</label>
                    <input asp-for="Amount" class="form-control rounded-3" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control rounded-3" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control rounded-3" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-warning rounded-3">
                    Update Budget
                </button>
                <a asp-action="Budgets" class="btn btn-secondary rounded-3 ms-2">
                    Cancel
                </a>
            </form>

            <!-- ================= ACTIVATE / DEACTIVATE ================= -->
            <div class="mt-4">
                @if (Model.IsActive)
                {
                    <form asp-action="DeactivateBudget" asp-route-id="@Model.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-danger rounded-3"
                                onclick="return confirm('Deactivate this budget?');">
                            Deactivate Budget
                        </button>
                    </form>
                }
                else
                {
                    <form asp-action="ActivateBudget" asp-route-id="@Model.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-success rounded-3"
                                onclick="return confirm('Activate this budget? It will deactivate the current active budget.');">
                            Activate Budget
                        </button>
                    </form>
                }
            </div>

        </div>
    </div>

</div>