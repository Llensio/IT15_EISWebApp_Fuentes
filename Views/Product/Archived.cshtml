@model IEnumerable<Product>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Archived Products";
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Archived Products</h2>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Back to Products
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Product Name</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Category</td>
                                <td>₱ @item.Price.ToString("N2")</td>
                                <td>@item.StockQuantity</td>
                                <td>@item.Status</td>
                                <td class="text-center">
                                    <a asp-action="Restore" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                                        <i class="fas fa-undo me-1"></i>Restore
                                    </a>
                                    <a asp-action="DeletePermanent" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash me-1"></i>Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .table thead th {
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }

    .x-small {
        font-size: 0.7rem;
    }

    tr.opacity-75:hover {
        opacity: 1 !important;
        transition: opacity 0.2s;
    }

    .btn-outline-success:hover {
        color: #fff;
    }

    .btn-outline-danger:hover {
        color: #fff;
    }
</style>