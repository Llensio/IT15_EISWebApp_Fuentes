@model SalesDashboardVM

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Analytics Hub";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.9);
        --accent-primary: #6366f1;
        --accent-success: #10b981;
        --accent-warning: #f59e0b;
        --accent-danger: #ef4444;
        --text-main: #1e293b;
        --text-muted: #64748b;
    }

    body {
        background-color: #f1f5f9;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--text-main);
    }

    /* Dashboard Wrapper */
    .dashboard-wrapper {
        padding: 1.5rem;
    }

    /* Glass Cards */
    .glass-card {
        background: var(--glass-bg);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 20px;
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 20px -5px rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease;
    }

    .kpi-stat-card {
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
    }

        .kpi-stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px -5px rgba(0, 0, 0, 0.1);
        }

    /* Icon Styling */
    .icon-shape {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 1.25rem;
    }

    .stat-label {
        color: var(--text-muted);
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.025em;
    }

    .stat-value {
        font-size: 1.85rem;
        font-weight: 800;
        margin: 0;
    }

    /* Header Customization */
    .page-header {
        margin-bottom: 2rem;
    }

        .page-header h2 {
            font-weight: 800;
            letter-spacing: -0.02em;
        }

    /* Chart Containers */
    .chart-container {
        padding: 1.5rem;
        height: 350px;
    }

    .card-title-premium {
        font-weight: 700;
        font-size: 1.1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #f1f5f9;
        margin-bottom: 1.5rem;
    }

    /* Trending Indicators */
    .trend-badge {
        font-size: 0.75rem;
        padding: 4px 8px;
        border-radius: 8px;
        font-weight: 600;
    }
</style>

<div class="dashboard-wrapper">
    <div class="page-header d-md-flex align-items-center justify-content-between">
        <div>
            <h2 class="mb-1 text-dark">Business Overview</h2>
            @* <p class="text-muted small mb-0">Real-time data for your sales performance.</p> *@
        </div>
        @* <div class="mt-3 mt-md-0">
            <button class="btn btn-white glass-card border-0 px-4 py-2 me-2">
                <i class="bi bi-calendar3 me-2 text-primary"></i> Last 30 Days
            </button>
            <button class="btn btn-primary shadow-sm border-0 px-4 py-2" style="background: var(--accent-primary); border-radius: 12px;">
                <i class="bi bi-plus-lg me-1"></i> New Entry
            </button>
        </div> *@
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-sm-6">
            <div class="glass-card kpi-stat-card border-start border-4 border-primary">
                <div class="icon-shape bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-layers-half"></i>
                </div>
                <p class="stat-label mb-1"><span class="trend-badge bg-success bg-opacity-10 text-success">ACTIVE PRODUCTS</span></p>
                <div class="d-flex align-items-center justify-content-between">
                    <h3 class="stat-value">@Model.ActiveProducts</h3>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="glass-card kpi-stat-card border-start border-4 border-success">
                <div class="icon-shape bg-success bg-opacity-10 text-success">
                    <i class="bi bi-wallet2"></i>
                </div>
                <p class="stat-label mb-1">TOTAL REVENUE</p>
                <h3 class="stat-value">₱@Model.TotalRevenue.ToString("N0")</h3>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="glass-card kpi-stat-card border-start border-4 border-warning">
                <div class="icon-shape bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-lightning-charge"></i>
                </div>
                <p class="stat-label mb-1">UNITS DISPATCHED</p>
                <h3 class="stat-value">@Model.TotalUnitsSold.ToString("N0")</h3>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="glass-card kpi-stat-card border-start border-4 border-danger">
                <div class="icon-shape bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-trophy"></i>
                </div>
                <p class="stat-label mb-1">TOP PRODUCT</p>
                <h3 class="stat-value text-truncate" style="font-size: 1.4rem;">@Model.TopProduct</h3>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="glass-card p-4">
                <div class="card-title-premium d-flex justify-content-between align-items-center">

                    <span>Revenue Velocity</span>

                    <form method="get" class="d-flex gap-2">

                        <select name="fromMonth" class="form-select form-select-sm">

                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i" selected="@(Model.FromMonth == i)">
                                    @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                                </option>
                            }

                        </select>

                        <select name="toMonth" class="form-select form-select-sm">

                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i" selected="@(Model.ToMonth == i)">
                                    @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                                </option>
                            }

                        </select>

                        <button class="btn btn-sm btn-primary">Apply</button>

                    </form>

                </div>
                <div class="chart-container">
                    <canvas id="revenueFlowChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="glass-card p-4">
                <div class="card-title-premium">Product Affinity</div>
                <div class="chart-container">
                    <canvas id="productMixChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Universal Chart Settings
    Chart.defaults.font.family = "'Plus Jakarta Sans', sans-serif";
    Chart.defaults.color = '#64748b';

    // 1. Revenue Velocity 
    const revCtx = document.getElementById('revenueFlowChart').getContext('2d');
    const purpleGradiant = revCtx.createLinearGradient(0, 0, 0, 400);
    purpleGradiant.addColorStop(0, 'rgba(99, 102, 241, 0.2)');
    purpleGradiant.addColorStop(1, 'rgba(99, 102, 241, 0)');

    new Chart(revCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrends.Select(m => m.Month))),
            datasets: [{
                label: 'Revenue',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrends.Select(m => m.Revenue))),
                borderColor: '#6366f1',
                borderWidth: 4,
                tension: 0.4,
                fill: true,
                backgroundColor: purpleGradiant,
                pointBackgroundColor: '#fff',
                pointBorderColor: '#6366f1',
                pointBorderWidth: 2,
                pointRadius: 6,
                pointHoverRadius: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, border: { display: false } },
                y: { grid: { color: '#f1f5f9' }, border: { display: false } }
            }
        }
    });

    // 2. Product Affinity
    const prodCtx = document.getElementById('productMixChart').getContext('2d');
    new Chart(prodCtx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SalesByProduct.Select(s => s.ProductName))),
            datasets: [{
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SalesByProduct.Select(s => s.TotalRevenue))),
                backgroundColor: '#6366f1',
                borderRadius: 8,
                barThickness: 15
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, display: false },
                y: { grid: { display: false }, border: { display: false } }
            }
        }
    });
</script>