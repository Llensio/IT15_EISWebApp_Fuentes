@using System.Collections.Generic
@using System.Linq
@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using Executive_Fuentes.Data
@model Executive_Fuentes.Models.LoginViewModel

@inject SignInManager<ApplicationUser> SignInManager
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Executive Fuentes</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --bg-color: #f8fafc;
            --card-bg: #ffffff;
            --primary-blue: #0ea5e9;
            --dark-slate: #0f172a;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            width: 100%;
            max-width: 380px;
            padding: 2.5rem;
            background: var(--card-bg);
            border-radius: 16px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .brand-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .brand-logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--dark-slate);
            letter-spacing: -0.5px;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #64748b;
            margin-bottom: 0.5rem;
        }

        .input-group {
            background-color: #f1f5f9;
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid transparent;
            transition: all 0.2s;
        }

            .input-group:focus-within {
                border-color: var(--primary-blue);
                background-color: #fff;
                box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1);
            }

        .input-group-text {
            background-color: transparent;
            border: none;
            color: #94a3b8;
            padding-left: 1rem;
        }

        .form-control {
            background-color: transparent;
            border: none;
            padding: 0.75rem 1rem 0.75rem 0.5rem;
            font-size: 0.95rem;
        }

            .form-control:focus {
                background-color: transparent;
                box-shadow: none;
                outline: none;
            }

        .btn-login {
            background-color: var(--dark-slate);
            color: white;
            padding: 0.8rem;
            border-radius: 10px;
            font-weight: 600;
            width: 100%;
            border: none;
            margin-top: 1.5rem;
            transition: transform 0.1s active;
        }

            .btn-login:hover {
                background-color: #1e293b;
                color: white;
            }

            .btn-login:active {
                transform: scale(0.98);
            }
    </style>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
</head>
<body>

    <div class="login-card">
        <div class="brand-header">
            <div class="brand-logo">
                <i class="bi bi-shield-lock-fill text-info me-1"></i> ELF Executive Trade & Services
            </div>
            <p class="text-muted small mt-2">Secure Management Portal</p>
        </div>

        <form asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3 text-center"></div>

            <div class="mb-3">
                <label class="form-label">Username</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input asp-for="Username" class="form-control" placeholder="Enter your username" required autocomplete="username" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required autocomplete="current-password" />
                </div>
            </div>
            <div class="mb-3 text-center">
                <div class="g-recaptcha" data-sitekey="6LfwpIQsAAAAAAYUaiMCIvp9z1Ra0f7XUe100UHz"></div>
            </div>
            <button type="submit" class="btn-login">Sign In</button>
        </form>
    </div>

</body>
</html>