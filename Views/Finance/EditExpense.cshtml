@model Expense
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Expense";
}

<div class="container py-4">

    <div class="card shadow rounded-4 border-0">
        <div class="card-body p-4">

            <h4 class="mb-4">Edit Expense</h4>

            <form asp-action="EditExpense" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <input asp-for="Description" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Amount</label>
                    <input asp-for="Amount" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Expense Date</label>
                    <input asp-for="ExpenseDate" type="date" class="form-control rounded-3" />
                </div>

                <button type="submit" class="btn btn-warning rounded-3">
                    Update
                </button>

                <a asp-action="Expenses" class="btn btn-secondary rounded-3 ms-2">
                    Cancel
                </a>

            </form>

        </div>
    </div>

</div>